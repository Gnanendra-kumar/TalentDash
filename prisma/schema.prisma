// ──────────────────────────────────────────────
// TalentDash — Prisma Schema
// PostgreSQL with Company + Salary models
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}


// Datasource is configured via `prisma.config.ts` (Prisma v7+).
datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────

enum Level {
  L3
  L4
  L5
  L6
  SDE_I
  SDE_II
  SDE_III
  STAFF
  PRINCIPAL
  IC4
  IC5
}

enum Currency {
  INR
  USD
  GBP
  EUR
}

enum Source {
  CONTRIBUTOR
  SCRAPED
  AI_INFERRED
}

// ─── Company ────────────────────────────────────

model Company {
  id              String   @id @default(uuid())
  name            String              // Display name: "Google India"
  slug            String   @unique    // URL-safe: "google"
  normalizedName  String   @map("normalized_name") // Lowercase deduplication key
  industry        String
  headquarters    String
  foundedYear     Int?     @map("founded_year")
  headcountRange  String?  @map("headcount_range")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  salaries Salary[]

  @@index([normalizedName])
  @@map("companies")
}

// ─── Salary ─────────────────────────────────────

model Salary {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  role               String
  level              Level
  location           String
  currency           Currency
  experienceYears    Int      @map("experience_years")
  baseSalary         BigInt   @map("base_salary")
  bonus              BigInt   @default(0)
  stock              BigInt   @default(0)
  totalCompensation  BigInt   @map("total_compensation")
  source             Source
  confidenceScore    Decimal  @map("confidence_score") @db.Decimal(3, 2)
  isVerified         Boolean  @default(false) @map("is_verified")
  submittedAt        DateTime @map("submitted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Primary filter path
  @@index([companyId, level, location])
  // Sort paths
  @@index([totalCompensation])
  @@index([submittedAt])
  // Geo-level filter path
  @@index([location, level])
  @@map("salaries")
}
